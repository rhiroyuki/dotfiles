#!/bin/sh

chosen=$(printf "рџ”’ Lock\nрџ”„ Reboot\nвЏ» Shutdown\nрџљЄ Log Out" | rofi -p "Session:" -dmenu -i)

case "$chosen" in
  "рџ”’ Lock")      swaylock -f --image $HOME/dotfiles/wallpapers/cloudy.png --effect-blur 7x5 ;;
  "рџ”„ Reboot")    systemctl reboot ;;
  "вЏ» Shutdown")  systemctl poweroff ;;
  "рџљЄ Log Out")   swaymsg exit ;;
  *) exit 1 ;;
esac
