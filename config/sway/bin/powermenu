#!/bin/sh

chosen=$(printf "рџ”’ Lock\nрџ’¤ Suspend\nрџ”„ Reboot\nвЏ» Shutdown\nрџљЄ Log Out" | rofi -p "Session:" -dmenu -i)

case "$chosen" in
  "рџ”’ Lock")      swaylock -f -c 000000 ;;
  "рџ’¤ Suspend")   swaylock -f -c 000000 & systemctl suspend ;;
  "рџ”„ Reboot")    systemctl reboot ;;
  "вЏ» Shutdown")  systemctl poweroff ;;
  "рџљЄ Log Out")   swaymsg exit ;;
  *) exit 1 ;;
esac
