#!/bin/bash

# For each output, find its current resolution and apply the highest
# available refresh rate at that resolution.

swaymsg -t get_outputs --raw | jq -r '
  .[] | select(.active) |
  .name as $name |
  .current_mode.width as $w |
  .current_mode.height as $h |
  [ .modes[] | select(.width == $w and .height == $h) ] |
  sort_by(.refresh) | last |
  "\($name) \($w)x\($h)@\(.refresh / 1000)Hz"
' | while read -r name mode; do
  swaymsg output "$name" mode "$mode"
done
